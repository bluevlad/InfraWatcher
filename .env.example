# InfraWatcher Configuration
# Copy this file to .env and modify as needed

# Server
IW_HOST=0.0.0.0
IW_PORT=9090
IW_DEBUG=false

# Database
IW_DB_PATH=/app/data/infrawatcher.db

# Docker
IW_DOCKER_SOCKET=/var/run/docker.sock

# Health Check
IW_HEALTHCHECK_HOST=host.docker.internal
IW_HEALTHCHECK_TIMEOUT=3.0

# Scheduler intervals (seconds)
IW_METRICS_INTERVAL=10
IW_HEALTHCHECK_INTERVAL=30

# Data retention (hours)
IW_DATA_RETENTION_HOURS=24
