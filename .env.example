# InfraWatcher Configuration
# Copy this file to .env and modify as needed

# Server
IW_HOST=0.0.0.0
IW_PORT=9090
IW_DEBUG=false

# Database
IW_DB_PATH=/app/data/infrawatcher.db

# Docker
IW_DOCKER_SOCKET=/var/run/docker.sock

# Health Check
IW_HEALTHCHECK_HOST=host.docker.internal
IW_HEALTHCHECK_TIMEOUT=3.0

# Scheduler intervals (seconds)
IW_METRICS_INTERVAL=10
IW_HEALTHCHECK_INTERVAL=30

# Data retention (hours)
IW_DATA_RETENTION_HOURS=24

# Auth — Google ID Token + JWT (관리자 로그인)
# Google Cloud Console → OAuth 2.0 Client ID 발급값. 이미 다른 unmong 서비스와 공유 가능.
IW_GOOGLE_CLIENT_ID=
# JWT 서명 키 — `openssl rand -hex 32` 로 생성, 프로덕션에서 반드시 교체
IW_JWT_SECRET=change-me-in-production
IW_JWT_EXPIRE_MINUTES=480
# 관리자 화이트리스트 (콤마 구분, 소문자 비교). 이 리스트 외 Google 계정은 차단.
IW_SUPER_ADMIN_EMAILS=rainend00@gmail.com
